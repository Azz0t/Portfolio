# Empêche l'affichage de la liste des fichiers
Options -Indexes

# Interdire l'accès aux fichiers sensibles
<FilesMatch "\.(htaccess|htpasswd|ini|phps|fla|psd|log|sh)$">
    Require all denied
</FilesMatch>

# Protection des répertoires sensibles
<FilesMatch "(^config|^private|^admin)">
    Require all denied
</FilesMatch>

# Interdire l'accès aux fichiers système de backup
<FilesMatch "\.(bak|old|backup|sql)$">
    Require all denied
</FilesMatch>

# Serveurs Apache plus anciens (compatibilité)
Order Allow,Deny
Deny from all